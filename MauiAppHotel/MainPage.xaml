<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.MainPage"
             BackgroundColor="White"> <!-- fundo branco, setei branco nos outros também, bom pra não cansar a vista -->

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- hero com gradiente laranja-azul -->
            <Grid BackgroundColor="{StaticResource Primary}"
                  HeightRequest="220"
                  Padding="20">
                <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                    <!-- ícone de hotel (emoji) -->
                    <Label Text="🏨"
                           FontSize="48"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center" />
                    <!-- título principal -->
                    <Label Text="Hotel MAUI"
                           FontFamily="MontserratBold"
                           FontSize="36"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                    <!-- subtítulo -->
                    <Label Text="Sua estadia perfeita começa aqui"
                           FontFamily="MontserratRegular"
                           FontSize="16"
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- seção de boas-vindas -->
            <VerticalStackLayout Padding="24,20" Spacing="16">
                <Label Text="Bem-vindo!"
                       FontFamily="MontserratBold"
                       FontSize="28"
                       TextColor="{StaticResource Secondary}"
                       HorizontalTextAlignment="Center" />
                <Label Text="Encontre a acomodação ideal para você e sua família com os melhores preços!"
                       FontFamily="MontserratRegular"
                       FontSize="15"
                       TextColor="{StaticResource Gray600}"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.4" />
            </VerticalStackLayout>

            <!-- serviços em grid -->
            <Grid ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto"
                  Padding="16,0"
                  ColumnSpacing="12"
                  RowSpacing="12">

                <!-- reservar suíte -->
                <Frame Grid.Row="0" Grid.Column="0"
                       Padding="16"
                       CornerRadius="16"
                       HasShadow="True"
                       BackgroundColor="{StaticResource White}"
                       BorderColor="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="🛏️"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Reservar Suíte"
                               FontFamily="MontserratSemiBold"
                               FontSize="14"
                               TextColor="{StaticResource Secondary}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Escolha seu quarto ideal"
                               FontFamily="MontserratRegular"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReservarClicked" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- minhas reservas -->
                <Frame Grid.Row="0" Grid.Column="1"
                       Padding="16"
                       CornerRadius="16"
                       HasShadow="True"
                       BackgroundColor="{StaticResource White}"
                       BorderColor="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📋"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Ver Reserva"
                               FontFamily="MontserratSemiBold"
                               FontSize="14"
                               TextColor="{StaticResource Secondary}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Detalhes da hospedagem"
                               FontFamily="MontserratRegular"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReservaClicked" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- sobre -->
                <Frame Grid.Row="1" Grid.Column="0"
                       Padding="16"
                       CornerRadius="16"
                       HasShadow="True"
                       BackgroundColor="{StaticResource White}"
                       BorderColor="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="ℹ️"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Sobre"
                               FontFamily="MontserratSemiBold"
                               FontSize="14"
                               TextColor="{StaticResource Secondary}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Informações do app"
                               FontFamily="MontserratRegular"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSobreClicked" />
                    </Frame.GestureRecognizers>
                </Frame>

                <!-- contato -->
                <Frame Grid.Row="1" Grid.Column="1"
                       Padding="16"
                       CornerRadius="16"
                       HasShadow="True"
                       BackgroundColor="{StaticResource White}"
                       BorderColor="{StaticResource Gray100}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📞"
                               FontSize="36"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Contato"
                               FontFamily="MontserratSemiBold"
                               FontSize="14"
                               TextColor="{StaticResource Secondary}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Fale conosco"
                               FontFamily="MontserratRegular"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnContatoClicked" />
                    </Frame.GestureRecognizers>
                </Frame>
            </Grid>

            <!-- botão principal de ação -->
            <Button Text="Fazer Reserva"
                    FontFamily="MontserratBold"
                    FontSize="18"
                    Margin="24,20"
                    Padding="20,14"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="14"
                    Clicked="OnReservarClicked"
                    HorizontalOptions="Fill" />

            <!-- footer -->
            <Label Text="© 2026 Hotel MAUI - Todos os direitos reservados"
                   FontFamily="MontserratRegular"
                   FontSize="11"
                   TextColor="{StaticResource Gray400}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,20" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
