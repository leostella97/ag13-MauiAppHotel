<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">
	<!-- configuração da página título, navegação e cor de fundo -->

	<VerticalStackLayout VerticalOptions="CenterAndExpand" Padding="20" Spacing="15">
		<!-- stack para organizar os elementos verticalmente, com espaçamento entre eles -->

        <Label Text="Sobre"
               FontFamily="Kalam"
               FontSize="30"
               HorizontalTextAlignment="Center"
               TextColor="{StaticResource Primary}" /> <!-- título da página-->

		<Frame Padding="10">
			<!-- frame para as informações -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Nome do desenvolvedor:" />
                <Label Text="Leonardo Stella de Oliveira"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />

				<Label Text="Ano desenvolvido:" Margin="0,10,0,0" />
				<!-- margem para separar as seções -->
                <Label Text="2026"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>
        </Frame>

		<Button Text="Voltar" Clicked="Button_Voltar_Clicked" HorizontalOptions="Center" />
		<!-- botão para voltar à página anterior -->

    </VerticalStackLayout>

</ContentPage>
