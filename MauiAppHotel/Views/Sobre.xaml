<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White"> <!-- fundo branco -->

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- cabeçalho azul -->
            <Frame BackgroundColor="{StaticResource Secondary}"
                   CornerRadius="16"
                   Padding="20"
                   HasShadow="False"
                   BorderColor="Transparent">
                <VerticalStackLayout VerticalOptions="Center" Spacing="4"
                                     HorizontalOptions="Center">
                    <Label Text="ℹ️"
                           FontSize="36"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Sobre"
                           FontFamily="MontserratBold"
                           FontSize="28"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Conheça o desenvolvedor"
                           FontFamily="MontserratRegular"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- informações do dev -->
            <Frame Padding="24" CornerRadius="16" HasShadow="True"
                   BackgroundColor="White" BorderColor="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="👨‍💻 Desenvolvedor"
                               FontFamily="MontserratSemiBold"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="Leonardo Stella de Oliveira"
                               FontFamily="MontserratBold"
                               FontSize="20"
                               TextColor="{StaticResource Secondary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅 Ano"
                               FontFamily="MontserratSemiBold"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="2026"
                               FontFamily="MontserratBold"
                               FontSize="20"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🏨 Projeto"
                               FontFamily="MontserratSemiBold"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}" />
                        <Label Text="Hotel MAUI - App de Reservas"
                               FontFamily="MontserratRegular"
                               FontSize="16"
                               TextColor="{StaticResource Gray900}" />
                        <Label Text="Aplicativo .NET MAUI para gerenciamento de hospedagem"
                               FontFamily="MontserratRegular"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               LineHeight="1.4" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!--botão voltar -->
            <Button Text="← Voltar"
                    FontFamily="MontserratBold"
                    FontSize="16"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="14"
                    Padding="20,14"
                    Clicked="Button_Voltar_Clicked"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
