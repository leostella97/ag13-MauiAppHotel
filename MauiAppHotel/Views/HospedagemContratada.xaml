<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White"> <!-- fundo branco -->

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- cabeçalho verde -->
            <Frame BackgroundColor="{StaticResource Tertiary}"
                   CornerRadius="16"
                   Padding="20"
                   HasShadow="False"
                   BorderColor="Transparent">
                <VerticalStackLayout VerticalOptions="Center" Spacing="4"
                                     HorizontalOptions="Center">
                    <Label Text="✅"
                           FontSize="36"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Reserva Confirmada!"
                           FontFamily="MontserratBold"
                           FontSize="22"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- tipo de quarto -->
            <Frame Padding="20" CornerRadius="16" HasShadow="True"
                   BackgroundColor="White" BorderColor="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{Binding QuartoSelecionado.Descricao}"
                           FontFamily="MontserratBold"
                           FontSize="24"
                           TextColor="{StaticResource Secondary}"
                           HorizontalTextAlignment="Center" />
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="👤 Adultos"
                                   FontFamily="MontserratSemiBold"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding QntAdultos}"
                                   FontFamily="MontserratBold"
                                   FontSize="20"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="🧒 Crianças"
                                   FontFamily="MontserratSemiBold"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding QntCriancas}"
                                   FontFamily="MontserratBold"
                                   FontSize="20"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- período da estadia -->
            <Frame Padding="20" CornerRadius="16" HasShadow="True"
                   BackgroundColor="White" BorderColor="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="📅 Período"
                           FontFamily="MontserratBold"
                           FontSize="16"
                           TextColor="{StaticResource Secondary}" />
                    <Grid ColumnDefinitions="*, *, *"
                          RowDefinitions="Auto, Auto"
                          ColumnSpacing="8" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Check-in"
                               FontFamily="MontserratSemiBold"
                               FontSize="12"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="Check-out"
                               FontFamily="MontserratSemiBold"
                               FontSize="12"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="0" Grid.Column="2"
                               Text="Estadia"
                               FontFamily="MontserratSemiBold"
                               FontSize="12"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{Binding DataCheckIn, StringFormat='{}{0:dd/MM/yyyy}'}"
                               FontFamily="MontserratBold"
                               FontSize="15"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding DataCheckOut, StringFormat='{}{0:dd/MM/yyyy}'}"
                               FontFamily="MontserratBold"
                               FontSize="15"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="2"
                               Text="{Binding Estadia}"
                               FontFamily="MontserratBold"
                               FontSize="15"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- valor Total -->
            <Frame Padding="20" CornerRadius="16" HasShadow="True"
                   BackgroundColor="{StaticResource Secondary}"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="💰 Valor Total"
                           FontFamily="MontserratSemiBold"
                           FontSize="14"
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ValorTotal, StringFormat='{}{0:C}'}"
                           FontFamily="MontserratBold"
                           FontSize="28"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- botão voltar -->
            <Button Text="← Voltar"
                    FontFamily="MontserratBold"
                    FontSize="16"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="14"
                    Padding="20,14"
                    Clicked="Button_Clicked"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
