<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="ContratacaoHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White"> <!-- fundo branco -->

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- cabeçalho laranja (frame com cantos arredondados) -->
            <Frame BackgroundColor="{StaticResource Primary}"
                   CornerRadius="16"
                   Padding="16"
                   HeightRequest="100"
                   HasShadow="False"
                   BorderColor="Transparent">
                <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                    <Label Text="📝 Reserva"
                           FontSize="28"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Calcule sua diária"
                           FontFamily="MontserratBold"
                           FontSize="22"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- menu de navegação -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Início"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White"
                        CornerRadius="10"
                        Padding="16,8"
                        FontFamily="MontserratSemiBold"
                        Clicked="MenuInicio_Clicked" />
                <Button Text="Sobre"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        CornerRadius="10"
                        Padding="16,8"
                        FontFamily="MontserratSemiBold"
                        Clicked="MenuSobre_Clicked" />
            </HorizontalStackLayout>

            <!-- card principal do formulário -->
            <Frame Padding="20" CornerRadius="16" HasShadow="True"
                   BackgroundColor="White" BorderColor="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="16">

                    <!-- hóspedes -->
                    <Label Text="👥 Hóspedes"
                           FontFamily="MontserratBold"
                           FontSize="16"
                           TextColor="{StaticResource Secondary}" />

                    <Grid RowDefinitions="Auto, Auto"
                          ColumnDefinitions="*, *, 2*"
                          ColumnSpacing="10"
                          RowSpacing="12">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Adultos:"
                               FontFamily="MontserratSemiBold"
                               VerticalTextAlignment="Center" />

                        <Label Grid.Row="0" Grid.Column="1"
                               TextColor="{StaticResource Primary}"
                               FontFamily="MontserratBold"
                               FontSize="18"
                               Text="{Binding Value}"
                               BindingContext="{x:Reference stp_adultos}"
                               VerticalTextAlignment="Center" />

                        <Stepper Grid.Row="0" Grid.Column="2"
                                 x:Name="stp_adultos"
                                 Minimum="0" Maximum="10" Increment="1" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Crianças:"
                               FontFamily="MontserratSemiBold"
                               VerticalTextAlignment="Center" />

                        <Label Grid.Row="1" Grid.Column="1"
                               TextColor="{StaticResource Primary}"
                               FontFamily="MontserratBold"
                               FontSize="18"
                               Text="{Binding Value}"
                               BindingContext="{x:Reference stp_criancas}"
                               VerticalTextAlignment="Center" />

                        <Stepper Grid.Row="1" Grid.Column="2"
                                 x:Name="stp_criancas"
                                 Minimum="0" Maximum="10" Increment="1" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                    <!-- escolha da suíte -->
                    <Label Text="🛏️ Escolha sua Suíte"
                           FontFamily="MontserratBold"
                           FontSize="16"
                           TextColor="{StaticResource Secondary}" />

                    <Frame Padding="12" CornerRadius="12" HasShadow="False"
                           BackgroundColor="{StaticResource Gray100}" BorderColor="Transparent">
                        <Picker x:Name="pck_quarto"
                                Title="Selecione sua Acomodação"
                                FontFamily="MontserratRegular"
                                ItemDisplayBinding="{Binding Descricao}" />
                    </Frame>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                    <!-- período da estadia -->
                    <Label Text="📅 Período da Estadia"
                           FontFamily="MontserratBold"
                           FontSize="16"
                           TextColor="{StaticResource Secondary}" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Check-in:"
                                   FontFamily="MontserratSemiBold"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray600}" />
                            <DatePicker x:Name="dtpck_checkin"
                                        DateSelected="dtpck_checkin_DateSelected"
                                        Format="dd/MM/yyyy"
                                        FontFamily="MontserratRegular" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Check-out:"
                                   FontFamily="MontserratSemiBold"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray600}" />
                            <DatePicker x:Name="dtpck_checkout"
                                        Format="dd/MM/yyyy"
                                        FontFamily="MontserratRegular" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- botão avançar -->
            <Button Text="Avançar →"
                    FontFamily="MontserratBold"
                    FontSize="18"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="14"
                    Padding="20,14"
                    Clicked="Button_Clicked"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
